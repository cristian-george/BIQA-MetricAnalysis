{
  "root_directory": "../../Datasets/KonIQ-10K/",
  "train_directory": "train",
  "val_directory": "val",
  "train_lb": "train_labels.csv",
  "val_lb": "val_labels.csv",
  "augment": true,
  "batch_size": 8,
  "epoch_size": 40,
  "continue_train": {
    "from_epoch": 0,
    "from_weights": ""
  },
  "lr": {
    "name": "exponential_decay",
    "value": {
      "initial_lr": 1e-04,
      "final_lr": 5e-05,
      "staircase": false
    }
  },
  "loss": "mse",
  "callbacks": {
    "tensorboard": {
      "log_dir": "data/trained_on_KonIQ-10K/logs/efficientnet_v2_s_384x512_bsz8_MSE_KonIQ-10K/01",
      "histogram_freq": 1
    },
    "model_checkpoint": {
      "ckpt_dir": "data/trained_on_KonIQ-10K/models/efficientnet_v2_s_384x512_bsz8_MSE_KonIQ-10K/01",
      "ckpts": [
        {
          "monitor": "val_loss",
          "mode": "min",
          "save_best_only": true,
          "save_weights_only": true
        },
        {
          "monitor": "val_plcc",
          "mode": "max",
          "save_best_only": true,
          "save_weights_only": true,
          "early_stopping": {
            "patience": 5,
            "min_delta": 5e-4
          }
        }
      ]
    }
  }
}